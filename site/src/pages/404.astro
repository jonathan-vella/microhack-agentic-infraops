---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

const frontmatter = {
  title: "404",
  description: "Page not found. Check the URL or head back to the workshop guide.",
  editUrl: false,
  template: "splash",
  hero: {
    title: "404",
    tagline: "Page not found. Check the URL or head back to the workshop guide.",
  },
} as const;
---

<StarlightPage frontmatter={frontmatter}>
  <p>The page you requested does not exist in the workshop docs.</p>
  <ul>
    <li><a href="/">Go back to the home page.</a></li>
    <li><a href="/getting-started/">Open Getting Started.</a></li>
    <li>Use the site search to find a challenge or reference page.</li>
  </ul>
</StarlightPage>